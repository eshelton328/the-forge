# KiCad temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups/
*-cache*
*-bak
*-bak*
*~
~*
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
\#auto_saved_files#

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Local project settings (user-specific)
*.kicad_prl

# KiCad internal local history
.history/

# macOS
.DS_Store

# Output directories (generated by KiBot / CI)
output/
*/output/

# Local KiCad CLI reports (make erc / drc / fab-drc)
boards/**/erc.json
boards/**/drc*.json

# Board-level DRU files (fab rules are copied here temporarily by CI)
boards/**/*.kicad_dru

# CI temp home for kicad-cli Docker runs
.kicad-ci-home/
.kicad-export-home/

# ngspice fixture reports (scripts/sim/run_sim.py)
sim/fixtures/**/spice-report.md

# Assembled SPICE decks (scripts/sim/assemble.py)
boards/**/sim/assembled.cir

# KiCad → SPICE export consumed by assembly (scripts/sim/export_kicad_spice.py)
boards/**/sim/kicad_export.cir
boards/**/sim/kicad_export_toolchain.txt

# Generated board SPICE reports (make sim-board / run_sim.py)
boards/**/docs/spice-report.md

# Local issue body scratch files (optional)
sim/issue-bodies/

# Local cache (3D models, etc.)
.cache/
